{
  "name": "nestjs-trpc",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone monorepo for @nestjs/trpc with official showcase sample",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "example/*"
  ],
  "scripts": {
    "postinstall": "npm run build --workspace @nestjs/trpc",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "pretypecheck:client": "npm run build --workspace @nestjs/trpc",
    "typecheck:client": "npm run typecheck:client --workspace @nestjs/trpc-showcase",
    "presmoke:express": "npm run build --workspace @nestjs/trpc",
    "smoke:express": "npm run smoke:express --workspace @nestjs/trpc-showcase",
    "presmoke:fastify": "npm run build --workspace @nestjs/trpc",
    "smoke:fastify": "npm run smoke:fastify --workspace @nestjs/trpc-showcase",
    "ci:showcase": "npm run typecheck:client && npm run smoke:express && npm run smoke:fastify"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/mocha": "10.0.10",
    "@types/node": "25.4.0",
    "mocha": "11.7.5",
    "rimraf": "6.1.3",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
