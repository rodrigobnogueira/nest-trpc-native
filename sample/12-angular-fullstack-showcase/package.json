{
  "name": "nest-trpc-native-sample-12-angular-showcase",
  "version": "0.0.0",
  "private": true,
  "description": "Angular full-stack showcase for nest-trpc-native",
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "scripts": {
    "clean": "rimraf dist src/@generated frontend/.angular frontend/dist frontend/tsconfig.tsbuildinfo tsconfig.tsbuildinfo tsconfig.client.tsbuildinfo",
    "generate:types": "ts-node --transpile-only src/generate-types.ts",
    "build:api": "npm run generate:types && nest build",
    "build:web": "npm run generate:types && ng build --configuration production",
    "build": "npm run clean && npm run build:api && npm run build:web",
    "typecheck:web": "npm run generate:types && ngc -p frontend/tsconfig.app.json",
    "typecheck:client": "npm run generate:types && tsc --noEmit -p tsconfig.client.json && npm run typecheck:web",
    "smoke:api": "npm run generate:types && ts-node --transpile-only scripts/smoke-api.ts",
    "test": "npm run typecheck:client && npm run smoke:api && npm run build:web",
    "test:e2e": "npm run test",
    "start:api": "npm run generate:types && nest start",
    "start:api:dev": "npm run generate:types && nest start --watch",
    "start:web": "ng serve --host 127.0.0.1 --port 4200"
  },
  "dependencies": {
    "@angular/common": "21.2.11",
    "@angular/compiler": "21.2.11",
    "@angular/core": "21.2.11",
    "@angular/platform-browser": "21.2.11",
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "11.1.19",
    "@trpc/client": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "nest-trpc-native": "0.4.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zod": "^4.0.0",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular/build": "21.2.9",
    "@angular/cli": "21.2.9",
    "@angular/compiler-cli": "21.2.11",
    "@nestjs/cli": "11.0.21",
    "@types/node": "25.6.0",
    "rimraf": "6.1.3",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
